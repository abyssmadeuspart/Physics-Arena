<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework Condition="'$(BepuRunnerTargetFramework)' == ''">net8.0</TargetFramework>
    <TargetFramework Condition="'$(BepuRunnerTargetFramework)' != ''">$(BepuRunnerTargetFramework)</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>disable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\cases\*.cs" Link="Cases\%(Filename)%(Extension)" />
    <ProjectReference Include="..\BepuPhysics\BepuPhysics.csproj" SetConfiguration="Configuration=ReleaseNoProfiling" SetTargetFramework="TargetFramework=$(BepuRunnerTargetFramework)" />
    <ProjectReference Include="..\BepuUtilities\BepuUtilities.csproj" SetConfiguration="Configuration=Release" SetTargetFramework="TargetFramework=$(BepuRunnerTargetFramework)" />
  </ItemGroup>
</Project>
